{
  "name": "global-star-driver",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --runInBand --ci",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "deps:vuln": "node ./scripts/pre_push_dependency_vulnerability_audit.mjs",
    "deps:outdated": "node ./scripts/pre_push_dependency_obsolescence_check.mjs",
    "precommit:staged": "lint-staged --concurrent false",
    "prepush:gate": "bash ./scripts/pre_push_quality_gate.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "expo": "~54.0.0",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^0.577.0",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "^4.2.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "react-test-renderer": "^19.1.0",
    "tailwindcss": "^3.4.19"
  },
  "private": true,
  "overrides": {
    "@tootallnate/once": "3.0.1"
  }
}
