{
  "name": "global-star-driver",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix --max-warnings=0",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "deps:vuln": "node ./scripts/pre_push_dependency_vulnerability_audit.mjs",
    "deps:outdated": "node ./scripts/pre_push_dependency_obsolescence_check.mjs",
    "precommit:staged": "lint-staged --concurrent false",
    "prepush:gate": "bash ./scripts/pre_push_quality_gate.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "expo": "^55.0.0",
    "expo-blur": "~55.0.10",
    "expo-camera": "~55.0.10",
    "expo-image-manipulator": "~55.0.11",
    "expo-image-picker": "~55.0.13",
    "expo-linking": "~55.0.8",
    "expo-location": "~55.1.4",
    "expo-status-bar": "~55.0.4",
    "lucide-react-native": "^0.577.0",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3"
  },
  "devDependencies": {
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2"
  },
  "private": true
}
